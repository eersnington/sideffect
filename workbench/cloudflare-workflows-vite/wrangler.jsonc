{
  "name": "sideffect-cloudflare-workflows-vite",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-10",

  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
  },
  "workflows": [
    {
      "name": "sideffect-cloudflare-workflows-vite",
      "binding": "MY_WORKFLOW",
      "class_name": "MyWorkflow",
    },
  ],
}
